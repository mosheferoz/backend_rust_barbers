PROJECT_ID=your-project-id

# Rust bind address (keep 127.0.0.1 in production behind nginx)
BIND_ADDR=127.0.0.1:8080

# Comma-separated list of allowed origins for browsers (CORS).
# Examples:
# CORS_ALLOWED_ORIGINS=https://eventlyil.xyz,https://www.eventlyil.xyz
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_ORIGINS=

# Pulseem (optional, for reminders)
PULSEEM_API_KEY=
PULSEEM_FROM_NUMBER=

# Opportunities scheduler
OPPORTUNITIES_ENABLED=true
OPPORTUNITIES_INTERVAL_SECS=3600
OPPORTUNITIES_CONCURRENCY=4

